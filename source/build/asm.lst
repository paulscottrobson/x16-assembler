.1bc5	bd 27 04	lda $0427,x			lda 	AXBuffer,x 					; get the next caracter.
.1bc8	20 a7 1b	jsr $1ba7			jsr 	AXIsIdentifierBody 			; is it a body character
.1bcb	90 ea		bcc $1bb7			bcc 	_AXELLoop 					; if so add it to the label.
.1bcd	b9 09 04	lda $0409,y			lda 	AXLabelBuffer-1,y 			; set bit 7 of last character.
.1bd0	09 80		ora #$80			ora 	#$80
.1bd2	99 09 04	sta $0409,y			sta 	AXLabelBuffer-1,y
.1bd5	18		clc				clc 								; successfully acquired a label.
.1bd6	60		rts				rts
.1bd7					_AXELFail:
.1bd7	a9 02		lda #$02			lda 	#AXERRIdentifier			; bad label.
.1bd9	38		sec				sec
.1bda	60		rts				rts


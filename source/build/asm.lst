.1b97					_AXIFindLast:
.1b97	b2 30		lda ($30)			lda 	(AXTemp0)					; read the *next* link
.1b99	a8		tay				tay
.1b9a	b1 30		lda ($30),y			lda 	(AXTemp0),y
.1b9c	f0 0c		beq $1baa			beq 	_AXIFoundLast 				; if zero, we're at the last defined.
.1b9e	98		tya				tya 								; move to next.
.1b9f	18		clc				clc
.1ba0	65 30		adc $30				adc 	AXTemp0
.1ba2	85 30		sta $30				sta 	AXTemp0
.1ba4	90 f1		bcc $1b97			bcc 	_AXIFindLast
.1ba6	e6 31		inc $31				inc 	AXTemp0+1
.1ba8	80 ed		bra $1b97			bra 	_AXIFindLast
.1baa					_AXIFoundLast:
.1baa	a0 02		ldy #$02			ldy 	#AXID_Type 					; set the type to macro.
.1bac	a9 03		lda #$03			lda 	#AXIT_Macro
.1bae	91 30		sta ($30),y			sta 	(AXTemp0),y
.1bb0	28		plp				plp 								; type of operation required.
.1bb1	b0 0d		bcs $1bc0			bcs 	_AXIInsertNull
.1bb3	a2 00		ldx #$00			ldx 	#0 							; insert the buffer
.1bb5					_AXIInsertBuffer:
.1bb5	bd 7a 04	lda $047a,x			lda 	AXBuffer,x 					; if end of line insert $00 and exit
.1bb8	f0 08		beq $1bc2			beq 	_AXIInsertA
.1bba	20 ca 1b	jsr $1bca			jsr 	_AXIInsert 					; insert character
.1bbd	e8		inx				inx 								; do next
.1bbe	80 f5		bra $1bb5			bra 	_AXIInsertBuffer
.1bc0					_AXIInsertNull:

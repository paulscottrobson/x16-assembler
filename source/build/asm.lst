.1b8e					_AXIFindLast:
.1b8e	b2 30		lda ($30)			lda 	(AXTemp0)					; read the *next* link
.1b90	a8		tay				tay
.1b91	b1 30		lda ($30),y			lda 	(AXTemp0),y
.1b93	f0 0c		beq $1ba1			beq 	_AXIFoundLast 				; if zero, we're at the last defined.
